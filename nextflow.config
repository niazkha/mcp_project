// Nextflow configuration for large-scale genome analysis

profiles {
    standard {
        process.executor = 'local'
        process.cpus = 4
        process.memory = '8 GB'
    }
    
    cloud {
        process.executor = 'google-batch' // or 'awsbatch' depending on your cloud provider
        region = 'us-central1'
        
        // High-RAM scaling for heavy variant calling (GATK / BWA-MEM2)
        process {
            withName: 'alignment' {
                cpus = 16
                memory = '64 GB'
            }
            withName: 'variant_calling' {
                cpus = 32
                memory = '128 GB'
            }
        }
    }
}

// Automatically delete intermediate non-essential files to save storage space
cleanup = true

manifest {
    name = 'MCPH-Variant-Pipeline'
    author = 'Bioinformatics Researcher'
    description = 'Scalable WGS/Targeted pipeline for microcephaly genes'
    version = '1.0.0'
}
